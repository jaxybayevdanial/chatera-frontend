# Скопируйте в .env и подставьте свои значения
# Dev: Metro/Expo — порт 3000 (см. package.json scripts)
# RocketAPI (поиск пользователей Instagram)
EXPO_PUBLIC_ROCKETAPI_TOKEN=your-rocketapi-token
# Локальный proxy (npm run server): все запросы к API + картинки через него → прод по умолчанию
EXPO_PUBLIC_PROXY_URL=http://localhost:3002
EXPO_PUBLIC_CHATERA_API_URL=http://localhost:3002

